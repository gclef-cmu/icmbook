.ipynb_checkpoints
*/.ipynb_checkpoints
*/*/.ipynb_checkpoints
_build

# Python bytecode
__pycache__/
*.pyc

# Generated by `make book` (mirrored from upstream Pyquist README).
content/pyquist/_pyquist_readme.md

# Generated by `make wheels` (pyquist + sounddevice stub for the browser kernel).
_static/wheels/

# setuptools build artifacts from `make wheels` building the browser stubs.
tools/*/build/
tools/*/*.egg-info/

# Downloaded by `make vendor-thebe` (pinned thebe runtime bundles, self-hosted
# because the kernel worker must be same-origin; under vendor/ because
# anything .js in _static gets auto-registered as a page script).
vendor/

# Claude Code — local AI tools
.claude/
